# ── Home Assistant ──────────────────────────────────────────────────────────
HA_BASE_URL=http://homeassistant.local:8123
# Long-lived access token (Profile → Security → Long-Lived Access Tokens)
HA_TOKEN=your_long_lived_access_token_here
HA_CAMERA_ENTITY=camera.vivint_front_door
# Webhook ID to fire when doorbell button is pressed (create in HA automations)
HA_WEBHOOK_ID=vivint_doorbell_press

# ── SIP / Vivint ─────────────────────────────────────────────────────────────
# WebSocket SIP server URL (from HA Vivint card config or browser network tab)
SIP_WSS_URL=wss://sip.vivintsky.com:443
SIP_SERVER=sip.vivintsky.com
SIP_USERNAME=your_sip_username
SIP_PASSWORD=your_sip_password
# The doorbell's SIP address (user@domain)
SIP_DOORBELL_USERNAME=doorbell_extension
SIP_DOORBELL_DOMAIN=sip.vivintsky.com

# ── go2rtc ───────────────────────────────────────────────────────────────────
GO2RTC_PORT=1984
RTSP_PORT=8554

# ── ONVIF wrapper ────────────────────────────────────────────────────────────
ONVIF_PORT=8080
ONVIF_DEVICE_NAME=Vivint Front Door
ONVIF_STREAM_NAME=vivint_front
# Host IP that Frigate/HA will use to reach this service (your Docker host LAN IP)
ONVIF_HOST=192.168.1.100
